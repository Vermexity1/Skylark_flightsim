{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/index.js": {
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.js"
    },
    {
      "source": "/assets/:path*",
      "destination": "/frontend/assets/:path*"
    },
    {
      "source": "/src/:path*",
      "destination": "/frontend/src/:path*"
    },
    {
      "source": "/frontend",
      "destination": "/frontend/index.html"
    }
  ]
}
